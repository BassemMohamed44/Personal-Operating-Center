# Copy this file to ".env" and fill in your own values.
# ".env" itself is git-ignored and should NEVER be committed.

# --- Flask ---
POC_SECRET_KEY=change-this-to-a-long-random-string

# --- Access control ---
# Required for: shutdown/restart/sleep/lock/screenshot, kill process,
# run-command, restart-app, file manager delete/rename/upload/open,
# and the Watchdog's force-restart endpoint. CHANGE THIS.
POC_CONTROL_PIN=change-this-pin

# --- Paths ---
# Folder that holds your Python projects, shown in the Project Manager widget.
POC_PROJECTS_ROOT=./projects

# Starting folder for the File Manager widget. On Windows you can use
# something like C:\Users\YourName or C:\ to browse a whole drive.
POC_FM_ROOT=

# --- Dev mode ---
# 1 = enable Flask/Werkzeug auto-reload on file changes (development only).
# Leave at 0 when running under watchdog.py.
POC_DEBUG=0

# --- Watchdog ---
# Only needed if you want to override the defaults in watchdog.py.
# POC_WD_CHECK_INTERVAL=15
# POC_WD_FAIL_THRESHOLD=3
# POC_WD_STARTUP_GRACE=20
